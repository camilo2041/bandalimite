---
const links = [
  { href: '#musica',         label: 'Música' },
  { href: '#videos',         label: 'Videos' },
  { href: '#la-banda',       label: 'La Banda' },
  { href: '#contrataciones', label: 'Contrataciones' },
];
---

<nav class="nav">
  <a href="#inicio" class="nav-logo">
    <img src="/uploads/media/logo.jpeg" alt="Andrés y Su Banda Límite" />
  </a>

  <ul class="nav-links">
    {links.map(l => (
      <li><a href={l.href} class="nav-link">{l.label}</a></li>
    ))}
  </ul>

  <div class="nav-right">
    <div class="nav-socials">
      <!-- TODO: reemplazar con URL real del perfil de Instagram -->
      <a href="https://www.instagram.com" target="_blank" rel="noopener" class="social-icon" aria-label="Instagram">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </a>
      <!-- TODO: reemplazar con URL real del perfil de Facebook -->
      <a href="https://www.facebook.com" target="_blank" rel="noopener" class="social-icon" aria-label="Facebook">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </a>
      <!-- TODO: reemplazar con URL real del perfil de TikTok -->
      <a href="https://www.tiktok.com" target="_blank" rel="noopener" class="social-icon" aria-label="TikTok">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.28 6.28 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.96a8.27 8.27 0 0 0 4.83 1.54V7.05a4.85 4.85 0 0 1-1.06-.36z"/>
        </svg>
      </a>
      <!-- TODO: reemplazar con URL real del canal de YouTube -->
      <a href="https://www.youtube.com" target="_blank" rel="noopener" class="social-icon" aria-label="YouTube">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"/>
        </svg>
      </a>
    </div>
    <a href="#contrataciones" class="nav-cta">Contratar</a>
    <button class="hamburger-btn" id="hamburger" aria-label="Menú" aria-expanded="false">&#9776;</button>
  </div>
</nav>

<!-- Mobile menu -->
<div class="mobile-menu" id="mobile-menu" hidden>
  {links.map(l => (
    <a href={l.href} class="mobile-nav-link">{l.label}</a>
  ))}
  <a href="#contrataciones" class="mobile-nav-link gold">Contratar Ahora</a>
  <div class="mobile-socials">
    <!-- TODO: reemplazar con URL real del perfil de Instagram -->
    <a href="https://www.instagram.com" target="_blank" rel="noopener" class="mobile-social" aria-label="Instagram">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
      </svg>
      Instagram
    </a>
    <!-- TODO: reemplazar con URL real del perfil de Facebook -->
    <a href="https://www.facebook.com" target="_blank" rel="noopener" class="mobile-social" aria-label="Facebook">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
      </svg>
      Facebook
    </a>
    <!-- TODO: reemplazar con URL real del canal de YouTube -->
    <a href="https://www.youtube.com" target="_blank" rel="noopener" class="mobile-social" aria-label="YouTube">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
        <path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.4.6A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.9.6 9.4.6 9.4.6s7.5 0 9.4-.6a3 3 0 0 0 2.1-2.1A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"/>
      </svg>
      YouTube
    </a>
  </div>
</div>

<script>
  const btn = document.getElementById('hamburger')!;
  const menu = document.getElementById('mobile-menu')!;

  btn.addEventListener('click', () => {
    const open = !menu.hidden;
    menu.hidden = open;
    btn.setAttribute('aria-expanded', String(!open));
    btn.innerHTML = open ? '&#9776;' : '&#10005;';
  });

  menu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.hidden = true;
      btn.setAttribute('aria-expanded', 'false');
      btn.innerHTML = '&#9776;';
    });
  });
</script>
