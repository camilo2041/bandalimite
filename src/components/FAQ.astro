<style>
  .faq-section {
    padding: 80px 24px;
    background: var(--bg-2);
    position: relative;
  }
  .faq-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .faq-item {
    background: var(--bg-3);
    border: 1px solid var(--gold-12);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .faq-item[open] {
    border-color: var(--gold-35);
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  .faq-question {
    padding: 20px 24px;
    font-family: var(--font-h);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    user-select: none;
    transition: color 0.3s ease;
  }
  .faq-question::-webkit-details-marker {
    display: none;
  }
  .faq-question:hover {
    color: var(--gold);
  }
  .faq-icon {
    display: inline-flex;
    transition: transform 0.3s ease;
    color: var(--gold);
  }
  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }
  .faq-answer {
    padding: 0 24px 20px;
    font-family: var(--font-b);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--text-85);
    border-top: 1px solid rgba(217,164,65,0.05);
  }
  .faq-answer strong {
    color: var(--gold);
    font-weight: 700;
  }
  @media (max-width: 768px) {
    .faq-section {
      padding: 60px 16px;
    }
    .faq-question {
      padding: 16px;
      font-size: 1.05rem;
      gap: 12px;
    }
    .faq-answer {
      padding: 0 16px 16px;
      font-size: 0.95rem;
    }
  }
</style>
