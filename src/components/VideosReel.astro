---
const videos = [
  {
    src:    '/uploads/media/video-1.mp4',
    poster: '/uploads/media/video-1-poster.jpeg',
    title:  'En Vivo',
    sub:    'Presentación Norteña',
  },
  {
    src:    '/uploads/media/video-2.mp4',
    poster: '/uploads/media/video-2-poster.jpeg',
    title:  'Show',
    sub:    'Fiesta Especial',
  },
  {
    src:    '/uploads/media/video-3.mp4',
    poster: '/uploads/media/video-3-poster.jpeg',
    title:  'Concierto',
    sub:    'Velada Norteña',
  },
];

const whatsapp = 'https://wa.me/573223272593?text=Hola%2C%20vi%20el%20video%20de%20Andr%C3%A9s%20y%20Su%20Banda%20L%C3%ADmite%20y%20me%20interesa%20contratarlos%20para%20mi%20evento.';
---

<section class="videos-section" id="videos">
  <div class="section-header">
    <p class="section-label">Videos Destacados</p>
    <h2 class="section-heading">Nuestro Reel</h2>
    <div class="gold-divider"><span class="star">&#9733;</span></div>
  </div>

  <div class="reel-scroll" id="reel-scroll">
    {videos.map((v, i) => (
      <div class="reel-card" data-index={i} role="button" tabindex="0" aria-label={`Ver ${v.title} en pantalla completa`}>
        <div class="reel-progress"><div class="reel-progress-bar"></div></div>
        <video
          class="reel-video"
          poster={v.poster}
          data-src={v.src}
          muted
          loop
          playsinline
          preload="none"
        ></video>
        <button class="reel-mute-btn" data-muted="true" aria-label="Activar sonido">
          <svg class="icon-muted" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
          </svg>
          <svg class="icon-unmuted" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" hidden>
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.5 8.5a5 5 0 0 1 0 7M19 5.5a9 9 0 0 1 0 13"/>
          </svg>
        </button>
        <div class="reel-caption">
          <div class="reel-title">{v.title}</div>
          <div class="reel-subtitle">{v.sub}</div>
        </div>
      </div>
    ))}
  </div>
  <p class="scroll-hint">← desliza para ver más →</p>
</section>

<!-- Modal -->
<div class="modal-overlay" id="modal-overlay" hidden role="dialog" aria-modal="true" aria-label="Video player">
  <div class="modal-backdrop" id="modal-backdrop"></div>

  <button class="modal-mute-btn" id="modal-mute" aria-label="Activar sonido">
    <svg class="icon-unmuted" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" hidden>
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.5 8.5a5 5 0 0 1 0 7M19 5.5a9 9 0 0 1 0 13"/>
    </svg>
    <svg class="icon-muted" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>
    </svg>
  </button>

  <button class="modal-close" id="modal-close" aria-label="Cerrar">&#10005;</button>

  <button class="modal-nav-btn modal-btn-prev" id="modal-prev" aria-label="Anterior">&#8593;</button>

  <div class="modal-container" id="modal-container">
    <div class="modal-segments" id="modal-segments">
      {videos.map((_, i) => (
        <div class="modal-segment"><div class="modal-segment-fill" data-seg={i}></div></div>
      ))}
    </div>

    <video
      class="modal-video"
      id="modal-video"
      playsinline
      preload="none"
      muted
    ></video>

    <div class="modal-loading" id="modal-loading" aria-hidden="true"><span class="modal-spinner"></span></div>

    <div class="modal-tap-icon" id="modal-tap-icon" aria-hidden="true">
      <svg id="modal-tap-play" width="30" height="30" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      <svg id="modal-tap-pause" width="30" height="30" viewBox="0 0 24 24" fill="currentColor" hidden><path d="M6 5h4v14H6zM14 5h4v14h-4z"/></svg>
    </div>

    <div class="modal-scrim-top"></div>
    <div class="modal-scrim-bottom"></div>

    <div class="modal-caption">
      <p class="modal-caption-title" id="modal-caption-title"></p>
      <p class="modal-caption-sub" id="modal-caption-sub"></p>
    </div>

    <div class="modal-seek" id="modal-seek"><div class="modal-seek-bar" id="modal-seek-bar"></div></div>

    <div class="swipe-hint" id="swipe-hint">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.35)" stroke-width="1.5">
        <path d="M12 2l0 4M12 18l0 4M12 2l-3 3M12 2l3 3M12 22l-3-3M12 22l3-3"/>
      </svg>
      <span class="swipe-hint-text">DESLIZA PARA CAMBIAR</span>
    </div>
  </div>

  <button class="modal-nav-btn modal-btn-next" id="modal-next" aria-label="Siguiente">&#8595;</button>

  <a href={whatsapp} target="_blank" rel="noopener" class="modal-cta">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
    Contratar Ahora
  </a>
</div>

<script define:vars={{ videos }}>
  const overlay      = document.getElementById('modal-overlay');
  const backdrop     = document.getElementById('modal-backdrop');
  const container    = document.getElementById('modal-container');
  const video        = document.getElementById('modal-video');
  const hint         = document.getElementById('swipe-hint');
  const btnClose     = document.getElementById('modal-close');
  const btnMute      = document.getElementById('modal-mute');
  const btnPrev      = document.getElementById('modal-prev');
  const btnNext      = document.getElementById('modal-next');
  const loading      = document.getElementById('modal-loading');
  const tapIcon      = document.getElementById('modal-tap-icon');
  const tapPlayIcon  = document.getElementById('modal-tap-play');
  const tapPauseIcon = document.getElementById('modal-tap-pause');
  const captionTitle = document.getElementById('modal-caption-title');
  const captionSub   = document.getElementById('modal-caption-sub');
  const seek         = document.getElementById('modal-seek');
  const seekBar      = document.getElementById('modal-seek-bar');
  const segmentFills = Array.from(document.querySelectorAll('.modal-segment-fill'));

  let idx = 0;
  let tapIconTimer;

  function open(i) {
    document.querySelectorAll('.reel-video').forEach(v => v.pause());
    idx = i;
    render();
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    setTimeout(() => { hint.classList.add('hidden'); }, 2200);
  }

  function close() {
    video.pause();
    video.src = '';
    overlay.hidden = true;
    document.body.style.overflow = '';
    hint.classList.remove('hidden');
  }

  function render() {
    const v = videos[idx];
    video.src    = v.src;
    video.poster = v.poster;
    backdrop.style.backgroundImage = `url('${v.poster}')`;
    captionTitle.textContent = v.title;
    captionSub.textContent   = v.sub;
    seekBar.style.width = '0%';
    loading.classList.add('show');
    video.load();
    video.play().catch(() => {});
    btnPrev.hidden = idx === 0;
    btnNext.hidden = idx === videos.length - 1;

    segmentFills.forEach((fill, i) => {
      fill.style.width = i < idx ? '100%' : '0%';
    });
  }

  video.addEventListener('waiting', () => loading.classList.add('show'));
  video.addEventListener('playing', () => loading.classList.remove('show'));
  video.addEventListener('canplay', () => loading.classList.remove('show'));

  video.addEventListener('timeupdate', () => {
    if (!video.duration) return;
    const pct = (video.currentTime / video.duration) * 100;
    seekBar.style.width = `${pct}%`;
    if (segmentFills[idx]) segmentFills[idx].style.width = `${pct}%`;
  });

  video.addEventListener('ended', () => {
    if (idx < videos.length - 1) { idx++; render(); }
    else { video.currentTime = 0; video.play().catch(() => {}); }
  });

  // Tap the video to toggle play / pause, with a brief icon flash like TikTok
  function showTapIcon(isPlaying) {
    tapPlayIcon.hidden  = isPlaying;
    tapPauseIcon.hidden = !isPlaying;
    tapIcon.classList.add('show');
    clearTimeout(tapIconTimer);
    tapIconTimer = setTimeout(() => tapIcon.classList.remove('show'), 500);
  }

  video.addEventListener('click', () => {
    if (video.paused) { video.play().catch(() => {}); showTapIcon(true); }
    else { video.pause(); showTapIcon(false); }
  });

  // Tap-to-seek
  seek.addEventListener('click', e => {
    if (!video.duration) return;
    const rect = seek.getBoundingClientRect();
    const ratio = (e.clientX - rect.left) / rect.width;
    video.currentTime = ratio * video.duration;
  });

  // Mute toggle
  btnMute.addEventListener('click', () => {
    video.muted = !video.muted;
    btnMute.querySelector('.icon-muted').hidden   = !video.muted;
    btnMute.querySelector('.icon-unmuted').hidden = video.muted;
    btnMute.setAttribute('aria-label', video.muted ? 'Activar sonido' : 'Silenciar');
  });

  // Open from reel cards (ignore clicks on the mute button)
  document.querySelectorAll('.reel-card').forEach(card => {
    card.addEventListener('click', e => {
      if (e.target.closest('.reel-mute-btn')) return;
      open(Number(card.dataset.index));
    });
    card.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') open(Number(card.dataset.index));
    });
  });

  // Feed-style autoplay: only the preview in view actually plays, like TikTok/Reels
  const reelObserver = new IntersectionObserver(entries => {
    entries.forEach(entry => {
      const v = entry.target;
      if (entry.isIntersecting) {
        if (!v.src) { v.src = v.dataset.src; v.load(); }
        v.play().catch(() => {});
      } else {
        v.pause();
      }
    });
  }, { threshold: 0.6 });

  document.querySelectorAll('.reel-video').forEach(v => reelObserver.observe(v));

  // Progress bar per card, mirrors the playing preview
  document.querySelectorAll('.reel-card').forEach(card => {
    const v = card.querySelector('.reel-video');
    const bar = card.querySelector('.reel-progress-bar');
    v.addEventListener('timeupdate', () => {
      if (v.duration) bar.style.width = `${(v.currentTime / v.duration) * 100}%`;
    });
  });

  // Tap-to-unmute, TikTok-style
  document.querySelectorAll('.reel-mute-btn').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      const card = btn.closest('.reel-card');
      const v = card.querySelector('.reel-video');
      const nowMuted = !(btn.dataset.muted === 'true');
      v.muted = nowMuted;
      btn.dataset.muted = String(nowMuted);
      btn.querySelector('.icon-muted').hidden = !nowMuted;
      btn.querySelector('.icon-unmuted').hidden = nowMuted;
      btn.setAttribute('aria-label', nowMuted ? 'Activar sonido' : 'Silenciar');
    });
  });

  btnClose.addEventListener('click', close);
  overlay.addEventListener('click', e => { if (e.target === overlay) close(); });
  btnPrev.addEventListener('click', () => { if (idx > 0) { idx--; render(); } });
  btnNext.addEventListener('click', () => { if (idx < videos.length - 1) { idx++; render(); } });

  document.addEventListener('keydown', e => {
    if (overlay.hidden) return;
    if (e.key === 'Escape') close();
    if (e.key === 'ArrowUp'   && idx > 0)                  { idx--; render(); }
    if (e.key === 'ArrowDown' && idx < videos.length - 1)  { idx++; render(); }
    if (e.key === ' ') { e.preventDefault(); video.paused ? video.play().catch(() => {}) : video.pause(); }
  });

  // Swipe / drag
  let startY = 0;
  let dragging = false;
  const THRESHOLD = 60;

  function onDragStart(y) { startY = y; dragging = true; container.classList.add('dragging'); }
  function onDragEnd(y) {
    if (!dragging) return;
    dragging = false;
    container.classList.remove('dragging');
    container.style.transform = '';
    const delta = startY - y;
    if (delta > THRESHOLD && idx < videos.length - 1) { idx++; render(); }
    else if (delta < -THRESHOLD && idx > 0) { idx--; render(); }
  }

  container.addEventListener('mousedown',  e => onDragStart(e.clientY));
  window.addEventListener('mouseup',       e => { if (dragging) onDragEnd(e.clientY); });
  container.addEventListener('touchstart', e => onDragStart(e.touches[0].clientY), { passive: true });
  container.addEventListener('touchend',   e => onDragEnd(e.changedTouches[0].clientY));
</script>
