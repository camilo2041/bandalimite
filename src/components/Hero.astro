---
const whatsapp = 'https://wa.me/573223272593?text=Hola%2C%20vi%20su%20landing%20y%20me%20interesa%20contratar%20a%20Andr%C3%A9s%20y%20Su%20Banda%20L%C3%ADmite%20para%20mi%20evento.';
---

<section class="hero" id="inicio">
  <div
    class="hero-bg"
    style="background-image: url('/uploads/media/logo.jpeg');"
  ></div>
  <div class="hero-overlay"></div>

  <div class="hero-content">

    <!-- 1. Identificación rápida -->
    <span class="hero-badge"><span class="dot"></span>En vivo para tu evento</span>
    <p class="hero-eyebrow">Colombia &bull; Norteño &bull; Regional Mexicano</p>
    <h1 class="hero-title">
      Andrés y Su<br />
      <span class="accent">Banda Límite</span>
    </h1>

    <!-- 2. Propuesta de valor (corta y directa) -->
    <p class="hero-body">
      La agrupación norteña que prende cualquier celebración en Bogotá y
      Cundinamarca. Show profesional con acordeón, bajo, tarolas y sonido
      incluido &mdash; repertorio amplio y experiencia comprobada.
    </p>

    <!-- 3. Credibilidad rápida -->
    <div class="hero-stats">
      <div class="hero-stat">
        <span class="hero-stat-number">5<span class="hero-stat-plus">+</span></span>
        <span class="hero-stat-label">Géneros musicales</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="hero-stat-number">4</span>
        <span class="hero-stat-label">Músicos en vivo</span>
      </div>
      <div class="hero-stat-divider"></div>
      <div class="hero-stat">
        <span class="hero-stat-number">24<span class="hero-stat-plus">h</span></span>
        <span class="hero-stat-label">Tiempo de respuesta</span>
      </div>
    </div>

    <!-- 4. CTAs (acción principal arriba del pliegue) -->
    <div class="hero-actions">
      <a href={whatsapp} target="_blank" rel="noopener" class="btn btn-gold">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        Contratar por WhatsApp
      </a>
      <a href="#videos" class="btn btn-outline">Ver Videos</a>
    </div>
    <p class="hero-availability">
      <span class="hero-avail-dot"></span>
      Disponible &middot; Respondemos en menos de 24 horas
    </p>

    <!-- 5. Detalles del servicio (para quien quiere saber más) -->
    <ul class="hero-highlights">
      <li class="hero-highlight-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <rect x="9" y="2" width="6" height="12" rx="3"/><path d="M5 10v1a7 7 0 0 0 14 0v-1M12 18v4M9 22h6"/>
        </svg>
        Repertorio: Corridos, norteños, popular, regional mexicano y éxitos del momento
      </li>
      <li class="hero-highlight-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/>
        </svg>
        Show profesional con acordeón, bajo y tarolas
      </li>
      <li class="hero-highlight-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M19 8a5 5 0 0 1 0 8M15.5 10.5a2 2 0 0 1 0 3"/>
        </svg>
        Sonido incluido para eventos pequeños y medianos
      </li>
      <li class="hero-highlight-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="9" r="6"/><path d="M8.5 14 7 22l5-2.5L17 22l-1.5-8"/>
        </svg>
        Puntualidad y presentación que su evento merece
      </li>
    </ul>

    <!-- 6. Audiencia objetivo -->
    <p class="hero-events-label">Tocamos en:</p>
    <div class="hero-event-chips">
      <span class="hero-event-chip">Matrimonios</span>
      <span class="hero-event-chip">15 Años</span>
      <span class="hero-event-chip">Grados</span>
      <span class="hero-event-chip">Primeras Comuniones</span>
      <span class="hero-event-chip">Fiestas de Empresa</span>
      <span class="hero-event-chip">Serenatas</span>
      <span class="hero-event-chip">Asados</span>
      <span class="hero-event-chip">Remates</span>
    </div>

    <!-- 7. Firma memorable -->
    <p class="hero-quote">
      🎺 Pa' las que se bailan, se cantan y se pistean &mdash; Andrés y Su Banda Límite EN VIVO
    </p>

  </div>
</section>
