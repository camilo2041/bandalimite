---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Andrés y Su Banda Límite — Música Norteña Colombiana',
  description = 'Contrata a Andrés y Su Banda Límite para tu evento. Norteño, popular, regional mexicano, tropical y carranguero de alta calidad. Disponibles en toda Colombia.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Ultra&family=Oswald:wght@300;400;500;600;700&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
